# Backend browser: "dolphin" (default) atau "playwright"
BROWSER_BACKEND=dolphin

# Local API Dolphin Anty (aplikasi Dolphin harus berjalan di mesin ini)
DOLPHIN_API_BASE=http://localhost:3001/v1.0
# Token API Dolphin — isi kalau Local API kamu meminta Authorization Bearer.
# Kosongkan jika tidak diperlukan.
DOLPHIN_API_TOKEN=
